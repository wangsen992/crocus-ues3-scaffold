Bootstrap: docker
From: ubuntu:22.04
Stage: build

%files
  ./spack.yaml /opt/spack.yaml

%post -c /bin/bash
  export DEBIAN_FRONTEND=noninteractive
  apt-get update && \
    apt-get install -y build-essential gcc gfortran git python3
  git clone https://github.com/spack/spack.git /usr/src/spack && \
    . /usr/src/spack/share/spack/setup-env.sh

  spack mirror add e4s https://cache.e4s.io/25.06 && \
    spack buildcache keys --install --trust && \
    spack env create openfoam /opt/spack.yaml && \
    spack -e openfoam install --cache-only

  # --- KEY FIX ---
    # Generate a STATIC script that contains all the environment variables
    # This avoids running 'spack env activate' at runtime.
    spack env activate --sh openfoam > /etc/profile.d/z_openfoam_env.sh

  . /etc/profile.d/z_openfoam_env.sh

  git clone https://github.com/wangsen992/openfoam-ext.git /opt/openfoam-ext || true
  # cd /opt/openfoam-ext && ./Allwmake



%environment
    # . /usr/src/spack/share/spack/setup-env.sh
    export SPACK_ROOT=/usr/src/spack
    export PATH=$PATH:$SPACK_ROOT/bin
    
    # Source the static environment we created in %post
    # This loads OpenFOAM and its dependencies instantly
    . /etc/profile.d/z_openfoam_env.sh

%test


%labels
  Author swang18@nd.edu
  Version v0.0.1

